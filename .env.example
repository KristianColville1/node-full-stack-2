# Server
PORT=3000
HOST=0.0.0.0
NODE_ENV=development
APP_VERSION=1.0.0

# Hapi cookie auth — both required at startup. COOKIE_PASSWORD must be >= 32 chars.
COOKIE_NAME=beanmap-session
COOKIE_PASSWORD=replace-with-a-long-random-string-of-at-least-32-chars

# JWT signing secret — Long random string.
JWT_SECRET=replace-with-a-different-long-random-string

# Storage backend: memory | json. REQUIRED in production (no default in prod).
# Test and development default to memory if unset.
STORAGE=memory

# Optional: email of the user to be promoted to admin on server start.
# No-op if the user hasn't signed up yet — they'll be promoted on the next start.
ADMIN_EMAIL=

# DynamoDB — local dev. Compose overrides endpoint to http://dynamodb:8000.
DYNAMODB_ENDPOINT=http://localhost:8000
AWS_REGION=local
AWS_ACCESS_KEY_ID=local
AWS_SECRET_ACCESS_KEY=local
