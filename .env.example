# Server
PORT=3000
HOST=0.0.0.0
NODE_ENV=development
APP_VERSION=1.0.0

# Hapi cookie auth — both required at startup. COOKIE_PASSWORD must be >= 32 chars.
COOKIE_NAME=beanmap-session
COOKIE_PASSWORD=replace-with-a-long-random-string-of-at-least-32-chars

# Storage backend: memory | json
STORAGE=memory
