{{#if cafes.length}}
<div class="columns is-multiline is-variable is-4">
  {{#each cafes}}
  <div class="column is-full-mobile is-half-tablet is-one-third-desktop">
    <article class="card list-cafe-card">
      <div class="card-image">
        <figure class="image is-4by3">
          <img src="{{#if imageUrl}}{{imageUrl}}{{else}}/assets/images/placeholder.jpg{{/if}}"
               alt="{{name}}"
               loading="lazy">
        </figure>
        <span class="list-cafe-tag" style="background-color: {{categoryColour}};">{{category}}</span>
      </div>
      <div class="card-content">
        <h3 class="list-cafe-name">
          <a href="/cafes/{{_id}}" class="has-text-dark">{{name}}</a>
        </h3>
        {{#if description}}
        <p class="list-cafe-description">{{description}}</p>
        {{/if}}
        <div class="list-cafe-meta">
          {{#if latitude}}{{#if longitude}}
          <span class="list-cafe-meta-item">
            <span class="icon is-small"><i class="fas fa-map-marker-alt"></i></span>
            <span>{{latitude}}, {{longitude}}</span>
          </span>
          {{/if}}{{/if}}
          {{#if analytics.views}}
          <span class="list-cafe-meta-item">
            <span class="icon is-small"><i class="fas fa-eye"></i></span>
            <span>{{analytics.views}}</span>
          </span>
          {{/if}}
        </div>
      </div>
      <footer class="card-footer">
        <a class="card-footer-item list-cafe-link" href="/cafes/{{_id}}">View</a>
        {{#if canDelete}}
        <form class="card-footer-item list-cafe-delete" action="/cafes/{{_id}}/delete" method="POST" onsubmit="return confirm('Delete this cafe?');">
          <button type="submit" class="button is-danger is-small is-light" aria-label="Delete cafe">
            <span class="icon is-small"><i class="fas fa-trash-alt"></i></span>
            <span>Delete</span>
          </button>
        </form>
        {{/if}}
      </footer>
    </article>
  </div>
  {{/each}}
</div>
{{else}}
<p class="mb-4">No cafes yet.</p>
{{/if}}
