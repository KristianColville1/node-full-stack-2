      <span class="hamburger-box">
        <span class="hamburger-inner"></span>
      </span>
    </button>
  </div>
  <div class="navbar-menu" id="navMenu">
    <div class="navbar-end">
      {{#if user}}
      <a id="dashboard" class="navbar-item nav-link" href="/dashboard">Dashboard</a>
      <a id="cafes" class="navbar-item nav-link" href="/cafes">Cafes</a>
      <a id="about" class="navbar-item nav-link" href="/about">About</a>
