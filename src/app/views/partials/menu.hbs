        <span>Admin</span>
      </a>
      {{/if}}
      <a id="logout" class="navbar-item nav-link" href="/logout">Logout</a>
      {{else}}
      <a id="login" class="navbar-item nav-link" href="/login">Login</a>
      <a id="signup" class="navbar-item nav-link" href="/signup">Sign up</a>
      <a id="about" class="navbar-item nav-link" href="/about">About</a>
      {{/if}}
    </div>
  </div>
  </div>
</nav>

<script>
    if (document.getElementById("{{active}}")) document.getElementById("{{active}}").classList.add("is-active");
</script>
